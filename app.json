{
  "expo": {
    "name": "Agent App",
    "slug": "agentapp",
    "version": "1.0.0",
    "owner": "sabrina.cullen",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sabrinacullen.agentapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used to record audio for transcription.",
        "NSSpeechRecognitionUsageDescription": "Used to transcribe your voice captures.",
        "NSLocationWhenInUseUsageDescription": "Used to show weather for your current location.",
        "NSCalendarsUsageDescription": "Used to show and create events in your calendar.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6B4EFF"
        }
      ],
      "expo-audio",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to show weather for your current location."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Used to show and create events in your calendar."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "421bec15-03bf-4964-8434-a263560a7f39"
      }
    }
  }
}
